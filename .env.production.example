APP_ENV=prod
API_PORT=8000
INFERENCE_PORT=8001

INFERENCE_URL=http://inference:8001
QDRANT_URL=http://qdrant:6333
MINIO_ENDPOINT=http://minio:9000
OLLAMA_URL=http://ollama:11434
REDIS_URL=redis://redis:6379/0

MINIO_ROOT_USER=replace-me
MINIO_ROOT_PASSWORD=replace-me
MINIO_DOCUMENTS_BUCKET=guidance-documents
MINIO_RESULTS_BUCKET=guidance-job-results
QDRANT_COLLECTION=guidance_chunks

OLLAMA_MODEL=qwen2.5:0.5b
OLLAMA_EMBEDDING_MODEL=qwen3-embedding:0.6b

AUTH_VALIDATION_URL=https://your-auth-provider.example/validate
AUTH_VALIDATION_TIMEOUT_S=10
JWT_SECRET_KEY=some-long-random-secret-you-choose
JWT_ACCESS_TOKEN_EXP_MINUTES=60
JWT_ISSUER=mobicare-llm-api
JWT_AUDIENCE=mobicare-gateway
INTERNAL_SERVICE_TOKEN=replace-with-a-separate-long-random-secret

PRODUCTION_GUIDANCE_TOP_K=3
PRODUCTION_GUIDANCE_TEMPERATURE=0.2
PRODUCTION_GUIDANCE_MAX_TOKENS=256
PRODUCTION_GUIDANCE_USE_GRAPH_AUGMENTATION=true
PRODUCTION_GUIDANCE_PIPELINE_VARIANT=standard
PRODUCTION_GUIDANCE_ENABLE_RESPONSE_VERIFICATION=true
PRODUCTION_GUIDANCE_ENABLE_UNKNOWN_FALLBACK=true

PRODUCTION_INGESTION_CLEANING_STRATEGY=deep
PRODUCTION_INGESTION_CHUNKING_STRATEGY=naive
PRODUCTION_INGESTION_CHUNK_SIZE=300
PRODUCTION_INGESTION_CHUNK_OVERLAP=100
INGESTION_COLLECTION_DELETE_ENABLED=true

# Optional finetuning-experiments playground helpers
PLAYGROUND_GATEWAY_BASE_URL=http://localhost:8000
PLAYGROUND_GATEWAY_AUTH_EMAIL=playground@mobicare.local
PLAYGROUND_GATEWAY_JWT_SECRET=some-long-random-secret-you-choose
PLAYGROUND_GATEWAY_JWT_ISSUER=mobicare-llm-api
PLAYGROUND_GATEWAY_JWT_AUDIENCE=mobicare-gateway
