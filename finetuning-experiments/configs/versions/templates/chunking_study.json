{
  "label": "v0_1_minimal",
  "dataset_path": "./datasets/document_sets/benchmark_v1.json",
  "documents_version": "docs_v1",
  "notes": "Minimal end-to-end benchmark pipeline.",
  "change_note": "Initial benchmark runner with ingestion, source mapping, guidance scoring, and Streamlit UI.",
  "ingestion": {
    "cleaning_strategy": "deep",
    "chunking_strategy": "naive",
    "chunking_params": {
      "chunk_size": 300,
      "chunk_overlap": 100
    },
    "embedding_model": null,
    "delete_collection_first": true
  },
  "source_mapping": {
    "max_matches": 5,
    "page_window": 2,
    "page_offset_candidates": [0, -1, -2, 1, -3, 2, 3],
    "semantic_fallback_enabled": false,
    "include_chunk_pairs": true
  },
  "inference": {
    "top_k": 3,
    "temperature": 0.0,
    "max_tokens": 256,
    "retrieval_mode": "hybrid",
    "hybrid_dense_weight": 0.65,
    "hybrid_sparse_weight": 0.35,
    "use_graph_augmentation": true,
    "graph_max_extra_nodes": 2,
    "enable_query_rewriting": false,
    "enable_response_verification": false,
    "enable_regeneration": false,
    "max_regeneration_attempts": 1,
    "llm_model": null,
    "embedding_model": null,
    "prompt_engineering_label": "default",
    "use_example_response": false
  },
  "execution": {
    "gateway_url": "http://localhost:8000",
    "qdrant_url": "http://localhost:6333",
    "collection": "guidance_chunks",
    "batch_size": 256,
    "poll_interval_seconds": 2.0,
    "max_wait_seconds": 1800,
    "max_cases": 25,
    "warmup_cases": 1,
    "include_unanswerable": true,
    "output_dir": "./artifacts/runs"
  }
}
