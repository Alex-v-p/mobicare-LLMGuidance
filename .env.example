# Public ports (host -> container)
API_PORT=8000
INFERENCE_PORT=8001
OLLAMA_PORT=11434
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# Internal service URLs (used by API + inference)
INFERENCE_URL=http://inference:8001
QDRANT_URL=http://qdrant:6333
MINIO_ENDPOINT=http://minio:9000
OLLAMA_URL=http://ollama:11434

# MinIO credentials
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Default generation model. Keep this small for fast local testing, or switch to a larger one later.
OLLAMA_MODEL=qwen2.5:0.5b
# Examples for 12 GB VRAM: qwen2.5:3b-instruct, llama3.2:3b

INFERENCE_TIMEOUT_S=60
OLLAMA_TIMEOUT_S=120

# Redis queue / job state
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0
REDIS_JOB_QUEUE=guidance_jobs
JOB_TTL_SECONDS=604800

# MinIO result retention
MINIO_RESULTS_BUCKET=guidance-job-results
MINIO_JOB_RETENTION_DAYS=7

# Callback delivery
CALLBACK_TIMEOUT_S=10
CALLBACK_MAX_ATTEMPTS=3

# Default embedding model. Re-ingest documents after changing this.
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
# Example larger embedding model: qwen3-embedding:4b
QDRANT_COLLECTION=guidance_chunks
MINIO_DOCUMENTS_BUCKET=guidance-documents
MINIO_DOCUMENTS_PREFIX=
RETRIEVAL_TOP_K=3

# JWT / auth provider
AUTH_VALIDATION_URL=http://your-auth-provider.example/validate
AUTH_VALIDATION_TIMEOUT_S=10
JWT_SECRET_KEY=replace-this-in-real-environments
JWT_ACCESS_TOKEN_EXP_MINUTES=60
JWT_ISSUER=mobicare-llm-api
JWT_AUDIENCE=mobicare-gateway
