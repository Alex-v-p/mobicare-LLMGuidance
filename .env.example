# Public ports (host -> container)
API_PORT=8000
INFERENCE_PORT=8001
OLLAMA_PORT=11434
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# Internal service URLs (used by API + inference)
